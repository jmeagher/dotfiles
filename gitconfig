[include]
	path = ~/.gitconfig_local

[diff]
	renames = true

[color]
	# Use colors in Git commands that are capable of colored output when outputting to the terminal
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = yellow
	changed = magenta
	untracked = cyan

# Use `origin` as the default remote on the `main` branch in all cases
[branch "main"]
	remote = origin
	merge = refs/heads/main

[push]
	# Only push the current branch
	default = current

[core]
	excludesfile = ~/.gitignore_global
	# splitIndex = true # Make it faster for big repos
	# untackedCache = true # Make it faster for big repos
	# fsmonitor = true # faster status checks https://github.blog/2022-06-29-improve-git-monorepo-performance-with-a-file-system-monitor/

[alias]
	copr = "!f() { git fetch -fu origin refs/pull/$1/head:pr-$1; git checkout pr-$1; } ; f"
	prunepr = "!git for-each-ref refs/heads/pr-* --format='%(refname:short)' | while read ref ; do git branch -D $ref ; done"

[feature]
	# manyFiles = 1 # Make it faster for big repos

[pull]
	ff = only
[credential "https://gitlab.com"]
	helper = "!f() { printf 'username=oauth2\\npassword='; glab auth status --show-token --hostname gitlab.com 2>&1 | awk '/Token found:/{print $NF}'; }; f"
