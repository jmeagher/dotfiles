#!/usr/bin/env sh
# backslide - run backslide via Docker
# Mounts the current directory as /app and exposes port 4100 for the dev server.
# Usage: backslide [bs-args...]

# For docs on this see https://github.com/sinedied/backslide

exec docker run -it --rm --init -v "$(pwd):/app" -w /app -p 4100:4100 registry.gitlab.com/mpolitze/backslide-docker@sha256:002ef9723bee156d955c6873b5512250c7b59cd133fff8fc2c605f8a99b984f5 "$@"
